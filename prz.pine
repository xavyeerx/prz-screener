//@version=5
indicator("Harmonic PRZ Scanner", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=100)

// ============================================================
// INPUTS
// ============================================================
grp_t = "Tolerance"
tol1 = input.float(5, "Strict %", minval=1, maxval=10, step=0.5, group=grp_t)
tol2 = input.float(10, "Loose %", minval=5, maxval=20, step=0.5, group=grp_t)
en_t1 = input.bool(true, "Enable Strict", group=grp_t)
en_t2 = input.bool(true, "Enable Loose", group=grp_t)

grp_d = "Depth (on/off)"
en_d3  = input.bool(true,  "Depth 3",  group=grp_d)
en_d5  = input.bool(true,  "Depth 5",  group=grp_d)
en_d8  = input.bool(true,  "Depth 8",  group=grp_d)
en_d12 = input.bool(true,  "Depth 12", group=grp_d)
en_d18 = input.bool(false, "Depth 18", group=grp_d)
en_d20 = input.bool(true,  "Depth 20", group=grp_d)
en_d25 = input.bool(false, "Depth 25", group=grp_d)

grp_p = "Patterns"
en_g = input.bool(true, "Gartley", group=grp_p)
en_b = input.bool(true, "Bat", group=grp_p)
en_c = input.bool(true, "Crab", group=grp_p)
en_f = input.bool(true, "Butterfly", group=grp_p)
en_s = input.bool(true, "Shark", group=grp_p)

grp_v = "Visuals"
show_prz = input.bool(true, "Show PRZ Box", group=grp_v)
show_lines = input.bool(true, "Show Lines", group=grp_v)
show_lbl = input.bool(true, "Show Labels", group=grp_v)
max_dist = input.float(80, "Max PRZ Distance %", minval=10, maxval=500, step=10, group=grp_v, tooltip="Hanya tampilkan PRZ dalam jarak N% dari harga saat ini")
show_hist  = input.bool(true,  "Show Confirmed Reversals", group=grp_v, tooltip="Tampilkan PRZ lama yang sudah terbukti reversal SESUAI arah pola (tag ✓, warna pudar)")
show_flip  = input.bool(true,  "Show Flipped PRZ", group=grp_v, tooltip="Tampilkan PRZ yang ter-FLIP: pola memprediksi reversal turun tapi harga malah reversal naik (atau sebaliknya). Zona ini biasanya berubah jadi support/resistance baru. Tag ⚠FLIP.")
rev_bars   = input.int(5, "Reversal Confirm Bars", minval=2, maxval=20, group=grp_v, tooltip="Jumlah candle setelah harga menyentuh PRZ untuk konfirmasi reversal")
strict_bc  = input.bool(false, "Strict BC Projection", group=grp_p, tooltip="ON = wajibkan BC projection sesuai aturan Carney (pola sedikit tapi akurat). OFF = deteksi lebih banyak, termasuk bottom yang BC-nya di luar rentang ideal. Default OFF.")

// ============================================================
// OBJECT STORAGE — semua line/box/label disimpan agar bisa dihapus
// & digambar ulang tiap rekalkulasi (mencegah penumpukan & garis statis)
// ============================================================
var line[]  store_lines = array.new_line(0)
var box[]   store_boxes = array.new_box(0)
var label[] store_labels = array.new_label(0)

clearAll() =>
    while array.size(store_lines) > 0
        line.delete(array.pop(store_lines))
    while array.size(store_boxes) > 0
        box.delete(array.pop(store_boxes))
    while array.size(store_labels) > 0
        label.delete(array.pop(store_labels))

// ============================================================
// HELPERS
// ============================================================
safeDiv(a, b) => b != 0 ? a / b : 0.0
inR(v, ideal, t) => v >= ideal*(1-t/100) and v <= ideal*(1+t/100)
inMM(v, lo, hi, t) => v >= lo*(1-t/100) and v <= hi*(1+t/100)
// BC projection gate: kalau strict_bc OFF, selalu lolos; kalau ON, cek rentang.
bcGate(v, lo, hi, t) => not strict_bc or inMM(v, lo, hi, t)

// ============================================================
// PRZ STATUS — reaksi harga nyata di zona PRZ
// Mengembalikan:
//   0 = aktif (belum disentuh, atau disentuh tapi belum cukup bar)
//   1 = reversal CONFIRMED searah pola (bull→naik / bear→turun)
//   2 = invalid: ditembus searah dengan ekspektasi pola (gagal hold)
//   3 = FLIP: harga reversal BERLAWANAN arah pola
//       (pola bull tapi harga jatuh & balik turun dari zona = zona jadi resistance,
//        pola bear tapi harga naik tembus & balik naik dari zona = zona jadi support)
// ============================================================
// Mengembalikan [status, endTime]:
//   endTime = waktu bar terakhir yang masih berinteraksi dengan zona
//             (sentuhan terakhir, atau bar saat reversal/flip terkonfirmasi).
//             Dipakai untuk menentukan ujung kanan box agar hanya selebar area tersentuh.
// Mengembalikan [status, firstTouch, endTime]:
//   firstTouch = waktu candle PERTAMA yang menyentuh zona (sisi kiri box).
//                = 0 bila zona belum pernah disentuh.
//   endTime    = waktu candle terakhir yang masih berinteraksi (sisi kanan box).
przStatus(przHi, przLo, isBull, startTime) =>
    int result = 0
    bool touched = false
    bool broke = false        // sudah menembus zona berlawanan ekspektasi?
    int touchIdx = 0
    int firstTouch = 0
    int endTime = startTime
    int lookback = math.min(bar_index, 500)
    // scan dari pivot D (lama) maju ke sekarang: pakai indeks menurun
    for k = 0 to lookback
        int i = lookback - k
        if time[i] <= startTime
            continue
        float h = high[i]
        float l = low[i]
        float c = close[i]
        if not touched
            // sentuhan pertama: harga masuk ke dalam rentang zona
            if l <= przHi and h >= przLo
                touched := true
                touchIdx := i
                firstTouch := time[i]
                endTime := time[i]
        else
            // perbarui ujung selama harga masih menyentuh zona
            if l <= przHi and h >= przLo
                endTime := time[i]
            int barsSince = touchIdx - i
            if isBull
                // CONFIRMED: harga balik naik di atas zona sesuai ekspektasi bullish
                if barsSince >= rev_bars and c > przHi
                    result := broke ? 3 : 1   // kalau sebelumnya sempat tembus ke bawah = FLIP
                    endTime := time[i]
                    break
                // tembus ke bawah zona (berlawanan ekspektasi)
                if c < przLo * 0.97
                    broke := true
                    endTime := time[i]
            else
                // CONFIRMED: harga balik turun di bawah zona sesuai ekspektasi bearish
                if barsSince >= rev_bars and c < przLo
                    result := broke ? 3 : 1
                    endTime := time[i]
                    break
                // tembus ke atas zona (berlawanan ekspektasi)
                if c > przHi * 1.03
                    broke := true
                    endTime := time[i]
    // Sudah menembus tapi tidak pernah balik (tidak ada konfirmasi) = INVALID
    if broke and result == 0
        result := 2
    [result, firstTouch, endTime]

// ============================================================
// ZIGZAG D3
// ============================================================
var float[] p3p = array.new_float(0), var int[] p3b = array.new_int(0), var bool[] p3t = array.new_bool(0)
ph3 = ta.pivothigh(high,3,3)
pl3 = ta.pivotlow(low,3,3)
if not na(ph3)
    int sz = array.size(p3t)
    if sz > 0
        if array.get(p3t,sz-1)==true
            if ph3 > array.get(p3p,sz-1)
                array.set(p3p,sz-1,ph3), array.set(p3b,sz-1,time[3])
        else
            array.push(p3p,ph3), array.push(p3b,time[3]), array.push(p3t,true)
    else
        array.push(p3p,ph3), array.push(p3b,time[3]), array.push(p3t,true)
if not na(pl3)
    int sz = array.size(p3t)
    if sz > 0
        if array.get(p3t,sz-1)==false
            if pl3 < array.get(p3p,sz-1)
                array.set(p3p,sz-1,pl3), array.set(p3b,sz-1,time[3])
        else
            array.push(p3p,pl3), array.push(p3b,time[3]), array.push(p3t,false)
    else
        array.push(p3p,pl3), array.push(p3b,time[3]), array.push(p3t,false)
while array.size(p3p)>20
    array.shift(p3p), array.shift(p3b), array.shift(p3t)

