// ============================================================
// DRAW PRZ — menggambar zona setelah cek status reaksi harga.
// Mengembalikan: false jika pola di-skip (invalid/disembunyikan), true jika digambar.
// ============================================================
drawPRZ(przHi, przLo, bull, ci, pname, clr, isStrict, xi, xP, ai, aP, bi, bP, cP) =>
    bool drawn = false
    [status, firstTouch, endTime] = przStatus(przHi, przLo, bull, ci)
    bool isHist = status == 1
    bool isFlip = status == 3
    bool touched = firstTouch > 0
    bool skip = status == 2 or (isHist and not show_hist) or (isFlip and not show_flip)
    if not skip
        int barMs = time - time[1]
        // sisi kiri box = sentuhan pertama harga ke zona.
        // Bila belum pernah tersentuh, mulai dari titik C dengan lebar minimal 3 bar.
        int ps = touched ? firstTouch : ci
        int pe = touched ? endTime + barMs : ci + 3 * barMs
        int bw = isStrict ? 2 : 1
        // warna & transparansi sesuai status
        color zclr = isFlip ? color.yellow : clr
        int boxTransp = isFlip ? 85 : (isHist ? 92 : (isStrict ? 80 : 90))
        int borderTransp = isFlip ? 20 : (isHist ? 70 : 40)
        string style = isFlip ? line.style_solid : (isStrict ? line.style_solid : line.style_dashed)
        int borderW = isFlip ? bw + 1 : bw
        string pfix = isStrict ? "★ " : "☆ "
        string dir = bull ? "▲" : "▼"
        string tag = isFlip ? " ⚠FLIP" : (isHist ? " ✓" : "")
        if show_prz
            array.push(store_boxes, box.new(ps, przHi, pe, przLo, xloc=xloc.bar_time, border_color=color.new(zclr, borderTransp), bgcolor=color.new(zclr, boxTransp), border_width=borderW, border_style=style))
        if show_lbl
            array.push(store_labels, label.new(ps, przHi, pfix + dir + pname + " " + str.tostring(przLo, "#") + "-" + str.tostring(przHi, "#") + tag, xloc=xloc.bar_time, style=label.style_label_down, color=color.new(zclr, isFlip ? 40 : 60), textcolor=color.white, size=size.tiny))
        if show_lines
            string lsty = (isHist or isFlip) ? line.style_dotted : line.style_solid
            array.push(store_lines, line.new(xi, xP, ai, aP, xloc=xloc.bar_time, color=zclr, width=bw, style=lsty))
            array.push(store_lines, line.new(ai, aP, bi, bP, xloc=xloc.bar_time, color=zclr, width=bw, style=lsty))
            array.push(store_lines, line.new(bi, bP, ci, cP, xloc=xloc.bar_time, color=zclr, width=bw, style=lsty))
        drawn := true
    drawn

scan(pp, bb, tt, tolVal, isStrict) =>
    int cnt = 0
    int totalP = array.size(pp)
    if totalP >= 5
        int maxW = math.min(3, totalP - 4)
        for w = 0 to maxW
            int idx = totalP - 4 - w
            if idx >= 0
                float xP = array.get(pp, idx)
                float aP = array.get(pp, idx+1)
                float bP = array.get(pp, idx+2)
                float cP = array.get(pp, idx+3)
                int xi = array.get(bb, idx)
                int ai = array.get(bb, idx+1)
                int bi = array.get(bb, idx+2)
                int ci = array.get(bb, idx+3)
                bool xHi = array.get(tt, idx)
                bool bull = not xHi
                bool a1 = array.get(tt, idx) != array.get(tt, idx+1)
                bool a2 = array.get(tt, idx+1) != array.get(tt, idx+2)
                bool a3 = array.get(tt, idx+2) != array.get(tt, idx+3)
                if a1 and a2 and a3
                    float xa = math.abs(aP-xP)
                    float ab = math.abs(bP-aP)
                    float bc = math.abs(cP-bP)
                    float br = safeDiv(ab,xa)   // B retracement of XA
                    float cr = safeDiv(bc,ab)   // C retracement of AB
                    float bcp = safeDiv(bc,ab)  // BC projection

                    // ---- GARTLEY: B=0.618 XA, D=0.786 XA, BC proj 1.13–1.618 ----
                    if en_g and inR(br,0.618,tolVal) and inMM(cr,0.382,0.886,tolVal) and bcGate(bcp,1.13,1.618,tolVal)
                        float gd = bull ? aP-0.786*xa : aP+0.786*xa
                        float gr = xa*0.03
                        float ghi = gd+gr, float glo = gd-gr
                        if math.abs((gd-close)/close)*100 <= max_dist and glo > 0
                            if drawPRZ(ghi, glo, bull, ci, "Gartley", color.green, isStrict, xi, xP, ai, aP, bi, bP, cP)
                                cnt+=1

                    // ---- BAT: B=0.382–0.50 XA, D=0.886 XA, BC proj 1.618–2.618 ----
                    if en_b and inMM(br,0.382,0.50,tolVal) and inMM(cr,0.382,0.886,tolVal) and bcGate(bcp,1.618,2.618,tolVal)
                        float bd = bull ? aP-0.886*xa : aP+0.886*xa
                        float brr = xa*0.03
                        float bhi = bd+brr, float blo = bd-brr
                        if math.abs((bd-close)/close)*100 <= max_dist and blo > 0
                            if drawPRZ(bhi, blo, bull, ci, "Bat", color.blue, isStrict, xi, xP, ai, aP, bi, bP, cP)
                                cnt+=1

                    // ---- BUTTERFLY: B=0.786 XA, D=1.27 XA, BC proj 1.618–2.24 ----
                    if en_f and inR(br,0.786,tolVal) and inMM(cr,0.382,0.886,tolVal) and bcGate(bcp,1.618,2.24,tolVal)
                        float fd = bull ? aP-1.27*xa : aP+1.27*xa
                        float fr = xa*0.04
                        float fhi = fd+fr, float flo = fd-fr
                        if math.abs((fd-close)/close)*100 <= max_dist and flo > 0
                            if drawPRZ(fhi, flo, bull, ci, "Butterfly", color.purple, isStrict, xi, xP, ai, aP, bi, bP, cP)
                                cnt+=1

                    // ---- CRAB: B=0.382–0.618 XA, D=1.618 XA, BC proj 2.24–3.618 ----
                    if en_c and inMM(br,0.382,0.618,tolVal) and inMM(cr,0.382,0.886,tolVal) and bcGate(bcp,2.24,3.618,tolVal)
                        float cd = bull ? aP-1.618*xa : aP+1.618*xa
                        float crr = xa*0.05
                        float chi = cd+crr, float clo = cd-crr
                        if math.abs((cd-close)/close)*100 <= max_dist and clo > 0
                            if drawPRZ(chi, clo, bull, ci, "Crab", color.orange, isStrict, xi, xP, ai, aP, bi, bP, cP)
                                cnt+=1

                    // ---- SHARK: B=0.382–0.618 XC, D=0.886–1.13 XA, BC proj 1.13–1.618 ----
                    if en_s and inMM(br,0.382,0.618,tolVal) and bcp>=1.13*(1-tolVal/100) and bcGate(bcp,1.13,1.618,tolVal)
                        float su  = bull ? aP-0.886*xa : aP+0.886*xa
                        float sl2 = bull ? aP-1.13*xa  : aP+1.13*xa
                        float shi = math.max(su,sl2), float slo = math.min(su,sl2)
                        float smid = (shi+slo)/2
                        if math.abs((smid-close)/close)*100 <= max_dist and slo > 0
                            if drawPRZ(shi, slo, bull, ci, "Shark", color.red, isStrict, xi, xP, ai, aP, bi, bP, cP)
                                cnt+=1
    cnt
// ============================================================
// RUN ALL SCANS
// ============================================================
if barstate.islast
    clearAll()
    if en_d3 and en_t1
        scan(p3p,p3b,p3t,tol1,true)
    if en_d3 and en_t2
        scan(p3p,p3b,p3t,tol2,false)
    if en_d5 and en_t1
        scan(p5p,p5b,p5t,tol1,true)
    if en_d5 and en_t2
        scan(p5p,p5b,p5t,tol2,false)
    if en_d8 and en_t1
        scan(p8p,p8b,p8t,tol1,true)
    if en_d8 and en_t2
        scan(p8p,p8b,p8t,tol2,false)
    if en_d12 and en_t1
        scan(p12p,p12b,p12t,tol1,true)
    if en_d12 and en_t2
        scan(p12p,p12b,p12t,tol2,false)
    if en_d18 and en_t1
        scan(p18p,p18b,p18t,tol1,true)
    if en_d18 and en_t2
        scan(p18p,p18b,p18t,tol2,false)
    if en_d20 and en_t1
        scan(p20p,p20b,p20t,tol1,true)
    if en_d20 and en_t2
        scan(p20p,p20b,p20t,tol2,false)
    if en_d25 and en_t1
        scan(p25p,p25b,p25t,tol1,true)
    if en_d25 and en_t2
        scan(p25p,p25b,p25t,tol2,false)

